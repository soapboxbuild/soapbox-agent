{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://soapbox.build/templates/delivery-presentation/schema.json",
  "title": "Delivery Presentation payload",
  "description": "Deliverable-agnostic client delivery slide deck (decarb, RSRA, portfolio-analysis, retrofit, GRESB, ...). Injected into templates/delivery-presentation/layout-agent.html via <script id=\"report-data\">. Title and Agenda slides are auto-generated from deck meta + section grouping; do NOT author them. Every field is nullable — missing fields hide their element.",
  "type": "object",
  "properties": {
    "deck": {
      "type": ["object", "null"],
      "description": "Deck-level metadata. Drives the auto-generated title slide and per-slide footers.",
      "properties": {
        "title":           { "type": ["string", "null"], "description": "Deck title, e.g. 'Westminster Decarbonization Plan'" },
        "subtitle":        { "type": ["string", "null"], "description": "One-line framing under the title" },
        "client":          { "type": ["string", "null"], "description": "Client organization, e.g. 'Cortland'" },
        "asset":           { "type": ["string", "null"], "description": "Asset / portfolio name, e.g. 'Cortland Westminster'" },
        "date":            { "type": ["string", "null"], "description": "Presentation date as display string" },
        "presenter":       { "type": ["string", "null"], "description": "Presenter name(s)" },
        "engagement_type": { "type": ["string", "null"], "description": "Eyebrow on the title slide, e.g. 'decarbonization plan delivery'" },
        "confidential":    { "type": ["boolean", "null"], "description": "true shows a confidentiality mark on the title slide" }
      },
      "additionalProperties": false
    },
    "slides": {
      "type": ["array", "null"],
      "description": "Content slides. Rendered GROUPED in fixed section order (background, methodology, assumptions, results, revisions) regardless of array order; in-section order is preserved. Each section may have multiple slides.",
      "items": { "$ref": "#/definitions/slide" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "slide": {
      "type": "object",
      "properties": {
        "section": {
          "type": ["string", "null"],
          "enum": ["background", "methodology", "assumptions", "results", "revisions", null],
          "description": "Section this slide belongs to. Fixed render order: background -> methodology -> assumptions -> results -> revisions. Unknown/missing sections render last."
        },
        "eyebrow": { "type": ["string", "null"], "description": "Space Mono '// eyebrow' text; defaults to the section name" },
        "heading": { "type": ["string", "null"], "description": "Slide headline (Bricolage Grotesque 800)" },
        "sub":     { "type": ["string", "null"], "description": "Supporting sentence under the heading" },
        "blocks": {
          "type": ["array", "null"],
          "description": "Content blocks, rendered top-to-bottom. Keep density modest: ~1-3 blocks per slide.",
          "items": { "$ref": "#/definitions/block" }
        }
      },
      "additionalProperties": false
    },
    "block": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["bullets", "stats", "table", "bars", "questions", "quote", "two_col"]
        },
        "items": {
          "type": ["array", "null"],
          "description": "For bullets: array of strings. For stats: array of stat items. For bars: array of bar items. For questions: array of question items."
        },
        "headers": {
          "type": ["array", "null"],
          "items": { "type": ["string", "null"] },
          "description": "table only: column headers"
        },
        "rows": {
          "type": ["array", "null"],
          "items": { "type": "array", "items": { "type": ["string", "null"] } },
          "description": "table only: rows of cell strings"
        },
        "text":        { "type": ["string", "null"], "description": "quote only: quote text" },
        "attribution": { "type": ["string", "null"], "description": "quote only: attribution line" },
        "left":  { "type": ["array", "null"], "items": { "$ref": "#/definitions/block" }, "description": "two_col only: blocks in the left column" },
        "right": { "type": ["array", "null"], "items": { "$ref": "#/definitions/block" }, "description": "two_col only: blocks in the right column" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "stats" } } },
          "then": {
            "properties": {
              "items": {
                "type": ["array", "null"],
                "items": {
                  "type": "object",
                  "properties": {
                    "label":  { "type": ["string", "null"] },
                    "value":  { "type": ["string", "null"], "description": "Pre-formatted display value, e.g. '+$3.9M'" },
                    "sub":    { "type": ["string", "null"] },
                    "accent": { "type": ["boolean", "null"], "description": "true renders the dark green-gradient money tile (use sparingly: max one per results slide)" }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "bars" } } },
          "then": {
            "properties": {
              "items": {
                "type": ["array", "null"],
                "items": {
                  "type": "object",
                  "properties": {
                    "label":   { "type": ["string", "null"] },
                    "value":   { "type": ["number", "null"], "description": "Numeric magnitude; bars scale to the max absolute value" },
                    "display": { "type": ["string", "null"], "description": "Pre-formatted value label, e.g. '-42%'" }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "questions" } } },
          "then": {
            "properties": {
              "items": {
                "type": ["array", "null"],
                "items": {
                  "type": "object",
                  "properties": {
                    "q":      { "type": ["string", "null"], "description": "The assumption or question" },
                    "status": { "type": ["string", "null"], "enum": ["open", "resolved", "adjudicated", null] },
                    "note":   { "type": ["string", "null"], "description": "Resolution / context note" }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "bullets" } } },
          "then": {
            "properties": {
              "items": { "type": ["array", "null"], "items": { "type": ["string", "null"] } }
            }
          }
        }
      ]
    }
  }
}
